# Clerk (用户认证) - 从 clerk.com 获取
# https://clerk.com
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxx
CLERK_SECRET_KEY=sk_test_xxx
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# Daily.co (视频 SDK) - 从 daily.co 获取
# https://daily.co
NEXT_PUBLIC_DAILY_API_URL=https://api.daily.co/v1
DAILY_API_KEY=your-daily-api-key

# Resend (邮件发送) - 从 resend.com 获取
# https://resend.com
RESEND_API_KEY=re_xxx
RESEND_FROM_EMAIL=noreply@yourdomain.com

# Stripe (支付) - 从 stripe.com 获取 (测试模式)
# https://stripe.com
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# 产品配置
NEXT_PUBLIC_APP_URL=http://localhost:3000
FREE_TRIAL_MINUTES=100
FREE_TRIAL_DAYS=7

# Cloudflare (部署时自动注入，本地开发可选)
# D1_DATABASE_ID=your-d1-database-id
# R2_BUCKET_NAME=o2o-storage
